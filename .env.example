# Vercel/Next.js 런타임: Supavisor Transaction pooler (port 6543)
DATABASE_URL="postgresql://DB_USER.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?sslmode=require"

# Prisma CLI 마이그레이션: Supavisor Session pooler (port 5432) 또는 Direct connection
DIRECT_URL="postgresql://DB_USER.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Auth.js
AUTH_SECRET="replace-with-a-random-secret"
AUTH_KAKAO_ID=""
AUTH_KAKAO_SECRET=""

# 로컬에서 production 서버(next start)를 테스트할 때만 필요합니다.
# Vercel에서는 VERCEL 환경변수로 신뢰 호스트가 자동 설정됩니다.
# AUTH_TRUST_HOST="true"
